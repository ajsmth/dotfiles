#!/usr/bin/env zsh

set -euo pipefail
setopt local_options no_shwordsplit

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

die() {
  print -u2 -- "$1"
  exit 1
}

log() {
  print -u2 -- "[wt-create-session] $1"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

has_pending_changes() {
  ! git diff --quiet --ignore-submodules -- || ! git diff --cached --quiet --ignore-submodules --
}

default_base_ref() {
  local remote_head

  if command -v gh >/dev/null 2>&1; then
    local gh_base
    gh_base="$(gh repo view --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null || true)"
    if [[ -n "$gh_base" ]]; then
      print -- "$gh_base"
      return
    fi
  fi

  remote_head="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [[ -n "$remote_head" ]]; then
    print -- "${remote_head#origin/}"
    return
  fi

  if git rev-parse --verify --quiet refs/heads/main >/dev/null; then
    print -- 'main'
    return
  fi

  if git rev-parse --verify --quiet refs/heads/master >/dev/null; then
    print -- 'master'
    return
  fi

  print -- 'HEAD'
}

branch_exists() {
  local branch="$1"
  git show-ref --verify --quiet "refs/heads/${branch}"
}

prompt_value() {
  local prompt="$1"
  local default_value="${2:-}"
  local value=''

  if [[ -n "$default_value" ]]; then
    read -r "?${prompt} [${default_value}]: " value
    print -- "${value:-$default_value}"
    return
  fi

  read -r "?${prompt}: " value
  print -- "$value"
}

confirm_choice() {
  local answer=''

  while true; do
    read -r "?Continue? [Y/n]: " answer
    case "${answer:l}" in
      ''|y|yes)
        return 0
        ;;
      n|no)
        return 1
        ;;
      *)
        print -u2 -- 'Please answer y or n.'
        ;;
    esac
  done
}

prompt_pending_mode() {
  local answer=''

  while true; do
    print -u2 -- ''
    print -u2 -- '[wt-create-session] Pending changes detected.'
    print -u2 -- '[wt-create-session] Choose: [s] stash and apply in new worktree, [c] continue without changes, [q] abort'
    read -r "?Selection: " answer

    case "${answer:l}" in
      s|stash)
        print -- 'stash'
        return
        ;;
      c|continue)
        print -- 'continue'
        return
        ;;
      q|quit|abort)
        print -- 'abort'
        return
        ;;
      *)
        print -u2 -- '[wt-create-session] Invalid selection.'
        ;;
    esac
  done
}

create_stash() {
  local branch="$1"
  local stash_ref=''

  git stash push -u -m "wt-create-session:${branch}" >/dev/null || die 'Failed to create stash.'
  stash_ref="$(git stash list | sed -n '1s/:.*//p')"
  [[ -n "$stash_ref" ]] || die 'Created stash but could not resolve its reference.'
  print -- "$stash_ref"
}

main() {
  local branch='' base='' pending_mode='' stash_ref=''

  require_cmd git
  require_cmd wt
  require_cmd sesh

  git rev-parse --show-toplevel >/dev/null 2>&1 || die 'Not inside a git repository.'

  print -u2 -- ''
  print -u2 -- 'Create Worktrunk Branch'
  print -u2 -- ''

  while [[ -z "$branch" ]]; do
    branch="$(prompt_value 'Branch name')"
    [[ -n "$branch" ]] || print -u2 -- 'Branch name is required.'
  done

  if branch_exists "$branch"; then
    die "Local branch already exists: ${branch}"
  fi

  base="$(prompt_value 'Base branch (blank uses default)' "$(default_base_ref)")"

  print -u2 -- ''
  print -u2 -- "Branch: ${branch}"
  print -u2 -- "Base:   ${base}"
  print -u2 -- ''

  if ! confirm_choice; then
    die 'Aborted before creating worktree.'
  fi

  if has_pending_changes; then
    pending_mode="$(prompt_pending_mode)"
    case "$pending_mode" in
      stash)
        log 'Stashing pending changes for transfer to the new worktree'
        stash_ref="$(create_stash "$branch")"
        log "Created stash ${stash_ref}"
        ;;
      continue)
        log 'Proceeding without carrying over pending changes'
        ;;
      abort)
        die 'Aborted before creating worktree.'
        ;;
    esac
  fi

  log "Creating worktree for ${branch} from ${base}"
  if [[ -n "$stash_ref" ]]; then
    exec wt switch --create --base "$base" --no-cd -x "${HOME}/.local/bin/wt-finish-session '{{ worktree_path }}'" "$branch" -- "$stash_ref"
  fi

  exec wt switch --create --base "$base" --no-cd -x "${HOME}/.local/bin/wt-finish-session '{{ worktree_path }}'" "$branch"
}

main "$@"
