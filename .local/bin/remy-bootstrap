#!/usr/bin/env bash

set -euo pipefail

ensure_path_entry() {
  local entry="$1"

  case ":${PATH:-}:" in
    *":$entry:"*) ;;
    *)
      PATH="${PATH:+$PATH:}$entry"
      ;;
  esac
}

ensure_path_entry "/opt/homebrew/bin"
ensure_path_entry "/usr/local/bin"
ensure_path_entry "/usr/bin"
ensure_path_entry "/bin"
ensure_path_entry "/usr/sbin"
ensure_path_entry "/sbin"
export PATH

REMY_TS_ROOT="${REMY_TS_ROOT:-$HOME/dev/remy-ts}"
REMY_TS_WORKTREES_ROOT="${REMY_TS_WORKTREES_ROOT:-$HOME/dev/remy-ts-worktrees}"
PORT_MANIFEST_NAME="${PORT_MANIFEST_NAME:-.remy-sesh-ports.env}"
STATE_DIR="${REMY_BOOTSTRAP_STATE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/remy-bootstrap}"
REMY_GOOGLE_CLIENT_ID="${REMY_GOOGLE_CLIENT_ID:-323550473040-1a8t77cb6nk9hd6fneet42l4kig4gc0o.apps.googleusercontent.com}"
AWS_PROFILE="${REMY_AWS_PROFILE:-remy-dev}"
SELF_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

log() {
  printf '[remy-bootstrap] %s\n' "$*" >&2
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

load_nvm() {
  local nvm_dir="${NVM_DIR:-$HOME/.nvm}"
  local nvm_brew_prefix=''

  if declare -F nvm >/dev/null 2>&1; then
    return 0
  fi

  export NVM_DIR="$nvm_dir"
  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    # shellcheck disable=SC1090
    source "$NVM_DIR/nvm.sh"
    return 0
  fi

  if command -v brew >/dev/null 2>&1; then
    nvm_brew_prefix="$(brew --prefix nvm 2>/dev/null || true)"
    if [[ -n "$nvm_brew_prefix" && -s "$nvm_brew_prefix/nvm.sh" ]]; then
      # shellcheck disable=SC1090
      source "$nvm_brew_prefix/nvm.sh"
      return 0
    fi
  fi

  return 1
}

ensure_expected_node_version() {
  local repo_root="$1"
  local nvmrc_path="$repo_root/.nvmrc"
  local expected_version current_version

  [[ -f "$nvmrc_path" ]] || return 0
  expected_version="$(tr -d '[:space:]' < "$nvmrc_path")"
  [[ -n "$expected_version" ]] || return 0

  require_cmd node
  current_version="$(node -v)"
  if [[ "$current_version" != "$expected_version" ]]; then
    if load_nvm; then
      log "Activating Node $expected_version via nvm"
      if nvm use --silent "$expected_version" >/dev/null 2>&1; then
        current_version="$(node -v)"
      fi
    fi
  fi

  if [[ "$current_version" != "$expected_version" ]]; then
    die "Node version mismatch for $repo_root: expected $expected_version from .nvmrc, got $current_version from $(command -v node)."
  fi
}

copy_if_present() {
  local source_file="$1"
  local target_file="$2"

  [[ -f "$source_file" ]] || return 0
  mkdir -p "$(dirname "$target_file")"
  cp "$source_file" "$target_file"
}

normalize_path() {
  local input_path="$1"

  [[ -n "$input_path" ]] || return 1
  if [[ -d "$input_path" ]]; then
    (cd "$input_path" && pwd -P)
    return
  fi
  if [[ -e "$input_path" ]]; then
    (cd "${input_path%/*}" && printf '%s/%s\n' "$(pwd -P)" "${input_path##*/}")
    return
  fi
  printf '%s\n' "$input_path"
}

resolve_repo_root() {
  local input_path="$1"
  local resolved_root=''

  if [[ -d "$input_path" ]]; then
    resolved_root="$(git -C "$input_path" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$resolved_root" ]]; then
      normalize_path "$resolved_root"
      return
    fi
    return
  fi

  if [[ -f "$input_path" ]]; then
    resolved_root="$(git -C "${input_path%/*}" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$resolved_root" ]]; then
      normalize_path "$resolved_root"
      return
    fi
    return
  fi

  printf '\n'
}

is_remy_repo_root() {
  local repo_root="$1"
  local remy_root worktrees_root

  remy_root="$(normalize_path "$REMY_TS_ROOT")"
  worktrees_root="$(normalize_path "$REMY_TS_WORKTREES_ROOT")"

  [[ -n "$repo_root" ]] || return 1
  [[ "$repo_root" == "$remy_root" ]] && return 0
  [[ "$repo_root" == "$worktrees_root"/* ]] && return 0
  return 1
}

legacy_manifest_path() {
  local repo_root="$1"
  printf '%s/%s\n' "$repo_root" "$PORT_MANIFEST_NAME"
}

manifest_path() {
  local repo_root="$1"
  local repo_name repo_hash

  repo_name="$(basename "$repo_root")"
  repo_name="${repo_name//[^A-Za-z0-9._-]/-}"
  repo_hash="$(printf '%s' "$repo_root" | cksum | awk '{print $1}')"
  mkdir -p "$STATE_DIR"
  printf '%s/%s-%s.env\n' "$STATE_DIR" "$repo_name" "$repo_hash"
}

port_is_free() {
  local port="$1"

  ! lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

find_first_free_port_in_range() {
  local start_port="$1"
  local end_port="$2"
  local port

  for ((port = start_port; port <= end_port; port += 1)); do
    if [[ "$port" -eq 3001 ]]; then
      continue
    fi
    if port_is_free "$port"; then
      printf '%s\n' "$port"
      return 0
    fi
  done

  return 1
}

find_first_free_port_from() {
  local start_port="$1"
  local search_count="${2:-100}"
  local end_port=$((start_port + search_count))

  find_first_free_port_in_range "$start_port" "$end_port"
}

preferred_canvas_port() {
  if port_is_free 6523; then
    printf '6523\n'
    return 0
  fi

  find_first_free_port_from 6524 100
}

saved_ports_are_free() {
  local frontend_port="$1"
  local chef_port="$2"
  local canvas_port="$3"

  [[ -n "$frontend_port" && -n "$chef_port" && -n "$canvas_port" ]] || return 1
  port_is_free "$frontend_port" || return 1
  port_is_free "$chef_port" || return 1
  port_is_free "$canvas_port" || return 1
  return 0
}

load_existing_manifest() {
  local manifest="$1"

  if [[ -f "$manifest" ]]; then
    # shellcheck disable=SC1090
    source "$manifest"
  fi
}

write_manifest() {
  local repo_root="$1"
  local frontend_port="$2"
  local chef_port="$3"
  local canvas_port="$4"
  local manifest legacy_manifest

  manifest="$(manifest_path "$repo_root")"
  legacy_manifest="$(legacy_manifest_path "$repo_root")"

  cat >"$manifest" <<EOF
# Managed by remy-bootstrap.
REMY_FRONTEND_PORT=$frontend_port
REMY_CHEF_PORT=$chef_port
REMY_CANVAS_SYNC_PORT=$canvas_port
EOF

  if [[ -f "$legacy_manifest" ]]; then
    rm -f "$legacy_manifest"
  fi
}

aws_session_valid() {
  aws sts get-caller-identity --profile "$AWS_PROFILE" >/dev/null 2>&1
}

ensure_aws_session() {
  require_cmd aws

  if aws_session_valid; then
    printf 'AWS SSO session is valid for profile %s.\n' "$AWS_PROFILE"
    return 0
  fi

  printf 'Starting AWS SSO login for profile %s...\n' "$AWS_PROFILE"
  aws sso login --profile "$AWS_PROFILE"

  if ! aws_session_valid; then
    die "AWS SSO login did not produce a valid session for profile $AWS_PROFILE."
  fi

  printf 'AWS SSO session is ready.\n'
}

vpn_connected() {
  ifconfig | grep -E 'inet 10\.1\.' >/dev/null 2>&1
}

ensure_vpn_connection() {
  require_cmd ifconfig

  if vpn_connected; then
    printf 'VPN appears connected.\n'
    return 0
  fi

  printf 'VPN is not connected.\n'
  printf 'Open the AWS VPN Client and connect your Remy profile.\n'
  printf 'The repo docs describe this in apps/networking/README.md.\n'

  while ! vpn_connected; do
    printf '\nPress Enter after connecting the AWS VPN Client, or Ctrl-C to cancel.'
    read -r _
  done

  printf 'VPN connection detected.\n'
}

ensure_cloud_access() {
  printf 'Checking AWS authentication...\n'
  ensure_aws_session
  printf '\nChecking VPN connectivity...\n'
  ensure_vpn_connection
  printf '\nCloud access preflight complete.\n\n'
}

session_name_for_path() {
  local worktree_path="$1"
  local session_name

  session_name="$(basename "$worktree_path")"
  session_name="${session_name//[^A-Za-z0-9._-]/-}"
  printf '%s\n' "$session_name"
}

window_exists() {
  local session_name="$1"
  local window_name="$2"

  tmux list-windows -t "=$session_name" -F '#W' 2>/dev/null | grep -Fxq -- "$window_name"
}

bootstrap_shell_command() {
  local shell_path="${SHELL:-/bin/zsh}"

  printf '%q -i' "$shell_path"
}

window_startup_command() {
  local window_name="$1"
  local command=''

  case "$window_name" in
    editor)
      command='nvim'
      ;;
    llm)
      command='codex'
      ;;
    web)
      printf -v command 'if [[ -s "$HOME/.nvm/nvm.sh" ]]; then source "$HOME/.nvm/nvm.sh"; fi; nvm use --silent >/dev/null 2>&1 || true; frontend_port="$("%q" frontend-port .)" && pnpm --filter @remy/web-client start -- --port "$frontend_port"' "$SELF_PATH"
      ;;
    chef)
      command='if [[ -s "$HOME/.nvm/nvm.sh" ]]; then source "$HOME/.nvm/nvm.sh"; fi; nvm use --silent >/dev/null 2>&1 || true; cd apps/chef-service && pnpm start'
      ;;
    canvas)
      printf -v command 'if [[ -s "$HOME/.nvm/nvm.sh" ]]; then source "$HOME/.nvm/nvm.sh"; fi; nvm use --silent >/dev/null 2>&1 || true; canvas_port="$("%q" canvas-port .)" && pnpm --filter @remy/canvas-sync-service dev:instance --instance DevAndrew --profile %q --port "$canvas_port"' "$SELF_PATH" "$AWS_PROFILE"
      ;;
    *)
      die "Unknown window: $window_name"
      ;;
  esac

  printf '%s\n' "$command"
}

configure_window() {
  local session_name="$1"
  local window_name="$2"

  tmux set-window-option -t "=$session_name:$window_name" automatic-rename off >/dev/null 2>&1 || true
  tmux set-window-option -t "=$session_name:$window_name" allow-rename off >/dev/null 2>&1 || true
}

configure_service_window() {
  local session_name="$1"
  local window_name="$2"

  configure_window "$session_name" "$window_name"
  tmux set-window-option -t "=$session_name:$window_name" remain-on-exit on >/dev/null 2>&1 || true
}

create_window() {
  local session_name="$1"
  local worktree_path="$2"
  local window_name="$3"
  local command=''

  tmux new-window -d -t "=$session_name:" -n "$window_name" -c "$worktree_path"
  configure_window "$session_name" "$window_name"
  case "$window_name" in
    web|chef|canvas) configure_service_window "$session_name" "$window_name" ;;
  esac

  command="$(window_startup_command "$window_name")"
  tmux send-keys -t "=$session_name:$window_name" "$command" C-m
}

create_window_if_missing() {
  local session_name="$1"
  local worktree_path="$2"
  local window_name="$3"

  if window_exists "$session_name" "$window_name"; then
    return 0
  fi

  create_window "$session_name" "$worktree_path" "$window_name"
}

create_bootstrap_window_if_missing() {
  local session_name="$1"
  local worktree_path="$2"
  local current_window_name="$3"
  local command=''

  if window_exists "$session_name" bootstrap || [[ "$current_window_name" == "bootstrap" ]]; then
    return 0
  fi

  command="$(bootstrap_shell_command)"
  tmux new-window -d -t "=$session_name:" -n bootstrap -c "$worktree_path" "$command"
  configure_window "$session_name" bootstrap
}

restart_window_if_safe() {
  local session_name="$1"
  local worktree_path="$2"
  local window_name="$3"
  local current_window_name="$4"

  if [[ "$current_window_name" == "$window_name" ]]; then
    log "Skipping restart of current tmux window: $window_name"
    return 0
  fi

  if window_exists "$session_name" "$window_name"; then
    tmux kill-window -t "=$session_name:$window_name" >/dev/null 2>&1 || true
  fi

  create_window "$session_name" "$worktree_path" "$window_name"
}

sync_tmux_session() {
  local repo_root="$1"
  local current_session_name='' current_window_name=''

  [[ -n "${TMUX:-}" ]] || return 0

  require_cmd tmux
  current_session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
  current_window_name="$(tmux display-message -p '#W' 2>/dev/null || true)"

  if [[ -z "$current_session_name" ]]; then
    log "Could not resolve current tmux session; skipping tmux service sync"
    return 0
  fi

  log "Syncing tmux windows for current session $current_session_name"
  create_bootstrap_window_if_missing "$current_session_name" "$repo_root" "$current_window_name"
  create_window_if_missing "$current_session_name" "$repo_root" editor
  create_window_if_missing "$current_session_name" "$repo_root" llm
  restart_window_if_safe "$current_session_name" "$repo_root" web "$current_window_name"
  restart_window_if_safe "$current_session_name" "$repo_root" chef "$current_window_name"
  restart_window_if_safe "$current_session_name" "$repo_root" canvas "$current_window_name"
}

filter_env_without_managed_keys() {
  local file="$1"
  local managed_comment="$2"
  shift 2
  local keys_csv

  keys_csv="$(IFS=,; printf '%s' "$*")"

  if [[ ! -f "$file" ]]; then
    return 0
  fi

  awk -v managed_keys="$keys_csv" -v managed_comment="$managed_comment" '
    BEGIN {
      split(managed_keys, parts, ",");
      for (i in parts) {
        if (parts[i] != "") {
          managed[parts[i]] = 1;
        }
      }
      managed_header = "# " managed_comment;
    }
    {
      trimmed = $0;
      sub(/^[[:space:]]*/, "", trimmed);
      if (trimmed == managed_header) {
        next;
      }
      if (trimmed ~ /^[A-Za-z_][A-Za-z0-9_]*=/) {
        key = trimmed;
        sub(/=.*/, "", key);
        if (key in managed) {
          next;
        }
      }
      print;
    }
  ' "$file"
}

rewrite_env_with_managed_block() {
  local file="$1"
  local block_title="$2"
  shift 2
  local tmp_filtered tmp_output
  local -a entries=("$@")
  local -a keys=()
  local entry

  tmp_filtered="$(mktemp)"
  tmp_output="$(mktemp)"

  for entry in "${entries[@]}"; do
    keys+=("${entry%%=*}")
  done

  filter_env_without_managed_keys "$file" "$block_title" "${keys[@]}" >"$tmp_filtered"

  {
    cat "$tmp_filtered"
    if [[ -s "$tmp_filtered" ]]; then
      printf '\n'
    fi
    printf '# %s\n' "$block_title"
    for entry in "${entries[@]}"; do
      printf '%s\n' "$entry"
    done
  } >"$tmp_output"

  mv "$tmp_output" "$file"
  rm -f "$tmp_filtered"
}

bootstrap_repo() {
  local repo_root="$1"
  local source_root
  local manifest legacy_manifest
  local frontend_port='' chef_port='' canvas_port=''
  local frontend_offset='' preferred_chef='' preferred_canvas=''
  local web_client_env chef_env canvas_dev_vars
  local source_web_client_env source_chef_env source_canvas_dev_vars

  source_root="$(normalize_path "$REMY_TS_ROOT")"
  log "Bootstrapping repo: $repo_root"
  ensure_expected_node_version "$repo_root"
  log "Running pnpm install"
  (cd "$repo_root" && pnpm install)
  log "Finished pnpm install"

  manifest="$(manifest_path "$repo_root")"
  legacy_manifest="$(legacy_manifest_path "$repo_root")"
  load_existing_manifest "$manifest"
  if [[ ! -f "$manifest" && -f "$legacy_manifest" ]]; then
    load_existing_manifest "$legacy_manifest"
  fi

  if saved_ports_are_free "${REMY_FRONTEND_PORT:-}" "${REMY_CHEF_PORT:-}" "${REMY_CANVAS_SYNC_PORT:-}"; then
    log "Reusing existing port manifest"
    frontend_port="$REMY_FRONTEND_PORT"
    chef_port="$REMY_CHEF_PORT"
    canvas_port="$REMY_CANVAS_SYNC_PORT"
  else
    if [[ -n "${REMY_FRONTEND_PORT:-}" || -n "${REMY_CHEF_PORT:-}" || -n "${REMY_CANVAS_SYNC_PORT:-}" ]]; then
      log "Stored ports are unavailable; reallocating"
    else
      log "Allocating fresh ports"
    fi
    frontend_port="$(find_first_free_port_in_range 3000 3010)" || die "No free frontend port available in localhost:3000-3010"
    frontend_offset=$((frontend_port - 3000))
    preferred_chef=$((8000 + frontend_offset))
    preferred_canvas=$((6523 + frontend_offset))
    chef_port="$(find_first_free_port_from "$preferred_chef" 100)" || die "Could not find a free chef-service port"
    if [[ "$preferred_canvas" -le 6523 ]]; then
      canvas_port="$(preferred_canvas_port)" || die "Could not find a free canvas-sync-service port"
    else
      canvas_port="$(find_first_free_port_from "$preferred_canvas" 100)" || die "Could not find a free canvas-sync-service port"
    fi
  fi

  log "Using ports: frontend=$frontend_port chef=$chef_port canvas=$canvas_port"

  web_client_env="$repo_root/apps/web-client/.env.local"
  chef_env="$repo_root/apps/chef-service/.env"
  canvas_dev_vars="$repo_root/apps/canvas-sync-service/.dev.vars"
  source_web_client_env="$source_root/apps/web-client/.env.local"
  source_chef_env="$source_root/apps/chef-service/.env"
  source_canvas_dev_vars="$source_root/apps/canvas-sync-service/.dev.vars"

  if [[ "$repo_root" != "$source_root" ]]; then
    log "Syncing base env files from $source_root"
    copy_if_present "$source_web_client_env" "$web_client_env"
    copy_if_present "$source_chef_env" "$chef_env"
    copy_if_present "$source_canvas_dev_vars" "$canvas_dev_vars"
  fi

  if [[ -d "$repo_root/apps/web-client" ]]; then
    log "Updating web-client env"
    rewrite_env_with_managed_block \
      "$web_client_env" \
      "Managed by remy-bootstrap." \
      "VITE_AUTH_GOOGLE_CLIENT_ID=$REMY_GOOGLE_CLIENT_ID" \
      "VITE_CHEF_API_URL=http://localhost:$chef_port" \
      "VITE_CANVAS_SYNC_API_URL=ws://localhost:$canvas_port/api"
  fi

  if [[ -f "$chef_env" || -d "$repo_root/apps/chef-service" ]]; then
    local canvas_sync_api_key="${INBOUND_SERVICE_API_KEY:-}"
    if [[ -z "$canvas_sync_api_key" && -f "$chef_env" ]]; then
      canvas_sync_api_key="$(
        awk '
          /^[[:space:]]*CANVAS_SYNC_API_KEY=/ {
            line = $0
            sub(/^[[:space:]]*CANVAS_SYNC_API_KEY=/, "", line)
            print line
            exit
          }
        ' "$chef_env"
      )"
    fi

    log "Updating chef-service env"
    rewrite_env_with_managed_block \
      "$chef_env" \
      "Managed by remy-bootstrap." \
      "CORS_ALLOW_ORIGINS=*" \
      "PORT=$chef_port" \
      "CANVAS_SYNC_SERVICE_URL=localhost:$canvas_port" \
      "CANVAS_SYNC_API_KEY=$canvas_sync_api_key"
  fi

  if [[ -f "$canvas_dev_vars" || -f "$source_canvas_dev_vars" || -d "$repo_root/apps/canvas-sync-service" ]]; then
    local inbound_api_key="${INBOUND_SERVICE_API_KEY:-}"
    if [[ -z "$inbound_api_key" && -f "$chef_env" ]]; then
      inbound_api_key="$(
        awk '
          /^[[:space:]]*CANVAS_SYNC_API_KEY=/ {
            line = $0
            sub(/^[[:space:]]*CANVAS_SYNC_API_KEY=/, "", line)
            print line
            exit
          }
        ' "$chef_env"
      )"
    fi
    if [[ -n "$inbound_api_key" ]]; then
      log "Updating canvas-sync-service env"
      rewrite_env_with_managed_block \
        "$canvas_dev_vars" \
        "Managed by remy-bootstrap." \
        "INBOUND_SERVICE_API_KEY=$inbound_api_key"
    fi
  fi

  write_manifest "$repo_root" "$frontend_port" "$chef_port" "$canvas_port"
  log "Saved port manifest: $manifest"
  printf 'Remy ports: frontend=%s chef=%s canvas=%s\n' "$frontend_port" "$chef_port" "$canvas_port"
}

print_canvas_port() {
  local input_path="$1"
  local repo_root=''
  local manifest legacy_manifest

  [[ -n "$input_path" ]] || die "Usage: remy-bootstrap canvas-port <path>"

  repo_root="$(resolve_repo_root "$input_path")"
  [[ -n "$repo_root" ]] || die "Could not resolve repo root from: $input_path"

  manifest="$(manifest_path "$repo_root")"
  legacy_manifest="$(legacy_manifest_path "$repo_root")"
  load_existing_manifest "$manifest"
  if [[ -z "${REMY_CANVAS_SYNC_PORT:-}" && -f "$legacy_manifest" ]]; then
    load_existing_manifest "$legacy_manifest"
  fi

  [[ -n "${REMY_CANVAS_SYNC_PORT:-}" ]] || die "No remy canvas port found for: $repo_root"
  printf '%s\n' "$REMY_CANVAS_SYNC_PORT"
}

print_frontend_port() {
  local input_path="$1"
  local repo_root=''
  local manifest legacy_manifest

  [[ -n "$input_path" ]] || die "Usage: remy-bootstrap frontend-port <path>"

  repo_root="$(resolve_repo_root "$input_path")"
  [[ -n "$repo_root" ]] || die "Could not resolve repo root from: $input_path"

  manifest="$(manifest_path "$repo_root")"
  legacy_manifest="$(legacy_manifest_path "$repo_root")"
  load_existing_manifest "$manifest"
  if [[ -z "${REMY_FRONTEND_PORT:-}" && -f "$legacy_manifest" ]]; then
    load_existing_manifest "$legacy_manifest"
  fi

  [[ -n "${REMY_FRONTEND_PORT:-}" ]] || die "No remy frontend port found for: $repo_root"
  printf '%s\n' "$REMY_FRONTEND_PORT"
}

main() {
  local command="${1:-bootstrap}"
  local input_path="${2:-}"
  local repo_root

  require_cmd git
  require_cmd lsof
  require_cmd cksum

  case "$command" in
    bootstrap)
      [[ -n "$input_path" ]] || die "Usage: remy-bootstrap bootstrap <path>"
      repo_root="$(resolve_repo_root "$input_path")"
      log "Resolved repo root: ${repo_root:-<none>}"
      if ! is_remy_repo_root "$repo_root"; then
        log "Skipping non-Remy repo"
        exit 0
      fi
      bootstrap_repo "$repo_root"
      ensure_cloud_access
      sync_tmux_session "$repo_root"
      ;;
    canvas-port)
      print_canvas_port "$input_path"
      ;;
    frontend-port)
      print_frontend_port "$input_path"
      ;;
    *)
      if [[ -n "$command" && -z "$input_path" ]]; then
        repo_root="$(resolve_repo_root "$command")"
        log "Resolved repo root: ${repo_root:-<none>}"
        if ! is_remy_repo_root "$repo_root"; then
          log "Skipping non-Remy repo"
          exit 0
        fi
        bootstrap_repo "$repo_root"
        ensure_cloud_access
        sync_tmux_session "$repo_root"
        return
      fi
      die "Usage: remy-bootstrap [bootstrap] <path> | remy-bootstrap canvas-port <path> | remy-bootstrap frontend-port <path>"
      ;;
  esac
}

main "$@"
