#!/usr/bin/env zsh

set -euo pipefail
setopt local_options no_shwordsplit

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
LOG_FILE="${TMPDIR:-/tmp}/git-worktree-session.log"

log() {
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >>"$LOG_FILE"
}

usage() {
  cat <<'EOF'
Usage:
  git-worktree-session            Open picker
  git-worktree-session picker     Open picker
  git-worktree-session create <name>
  git-worktree-session open <name>

Creates git worktrees under .worktrees/<name> and uses branch names wt/<name>.
Each worktree gets its own tmux session named wt-<repo>-<name>.
In the picker, press x on a selected worktree to confirm removal.
EOF
}

die() {
  log "ERROR: $1"
  print -u2 -- "$1"
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

repo_common_dir() {
  local common_dir root

  root="$(repo_root)"
  common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return 1

  if [[ "$common_dir" != /* ]]; then
    common_dir="$(cd "$root" && cd "$common_dir" && pwd)"
  fi

  print -- "$common_dir"
}

repo_main_root() {
  dirname "$(repo_common_dir)"
}

repo_name() {
  basename "$(repo_main_root)"
}

worktrees_dir() {
  print -- "$(repo_main_root)/.worktrees"
}

sanitize_name() {
  local name="$1"

  [[ -n "$name" ]] || die 'Worktree name cannot be empty'
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die 'Worktree name must match [A-Za-z0-9._-]+'
}

branch_name() {
  print -- "wt/$1"
}

worktree_path() {
  print -- "$(worktrees_dir)/$1"
}

local_file_allowlist() {
  print -- '.env'
  print -- '.env.local'
  print -- '.env.development'
  print -- '.env.test'
  print -- '.env.production'
}

session_name() {
  local repo name

  repo="$(repo_name)"
  name="$1"
  repo="${repo//[^A-Za-z0-9._-]/-}"
  name="${name//[^A-Za-z0-9._-]/-}"
  print -- "${repo}/${name}"
}

current_base_ref() {
  local ref

  ref="$(git branch --show-current 2>/dev/null || true)"
  if [[ -n "$ref" ]]; then
    print -- "$ref"
    return
  fi

  if git rev-parse --verify --quiet refs/heads/main >/dev/null; then
    print -- 'main'
    return
  fi

  if git rev-parse --verify --quiet refs/heads/master >/dev/null; then
    print -- 'master'
    return
  fi

  print -- 'HEAD'
}

has_tmux_session() {
  tmux has-session -t "=$(session_name "$1")" 2>/dev/null
}

kill_tmux_session() {
  local name session

  name="$1"
  session="$(session_name "$name")"

  if has_tmux_session "$name"; then
    log "killing tmux session $session"
    tmux kill-session -t "=$session"
  fi
}

attach_or_switch() {
  local session

  session="$(session_name "$1")"
  log "attach_or_switch name=$1 session=$session tmux=${TMUX:-<none>}"

  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "=$session"
  else
    tmux attach-session -t "=$session"
  fi
}

ensure_tmux_session() {
  local name worktree_dir session

  name="$1"
  worktree_dir="$(worktree_path "$name")"
  session="$(session_name "$name")"
  log "ensure_tmux_session name=$name dir=$worktree_dir session=$session"

  [[ -d "$worktree_dir" ]] || die "Worktree does not exist: $worktree_dir"

  if ! has_tmux_session "$name"; then
    log "creating tmux session $session"
    tmux new-session -d -s "$session" -c "$worktree_dir"
  else
    log "tmux session already exists: $session"
  fi
}

copy_local_files_to_worktree() {
  local source_root target_root rel_path source_path target_path

  source_root="$(repo_root)"
  target_root="$1"

  while IFS= read -r rel_path; do
    source_path="${source_root}/${rel_path}"
    target_path="${target_root}/${rel_path}"

    [[ -f "$source_path" ]] || continue

    if [[ -e "$target_path" ]]; then
      log "copy_local_files skip existing target=$target_path"
      continue
    fi

    log "copy_local_files copy source=$source_path target=$target_path"
    cp -p "$source_path" "$target_path"
  done < <(local_file_allowlist)
}

create_worktree_dir() {
  local name worktree_dir branch base_ref

  name="$1"
  sanitize_name "$name"

  worktree_dir="$(worktree_path "$name")"
  branch="$(branch_name "$name")"
  base_ref="$(current_base_ref)"
  log "create_worktree name=$name dir=$worktree_dir branch=$branch base_ref=$base_ref"

  mkdir -p "$(worktrees_dir)"

  if [[ -d "$worktree_dir" ]]; then
    log "worktree already exists: $worktree_dir"
    return
  fi

  if git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
    log "adding existing branch worktree $branch"
    git worktree add "$worktree_dir" "$branch"
  else
    log "creating branch and worktree $branch"
    git worktree add -b "$branch" "$worktree_dir" "$base_ref"
  fi

  copy_local_files_to_worktree "$worktree_dir"
}

create_worktree() {
  local name

  name="$1"
  create_worktree_dir "$name"

  ensure_tmux_session "$name"
  attach_or_switch "$name"
}

open_worktree() {
  local name

  name="$1"
  log "open_worktree name=$name"
  sanitize_name "$name"
  ensure_tmux_session "$name"
  attach_or_switch "$name"
}

confirm_capture_worktree() {
  local name

  name="$1"
  gum confirm "Create worktree '$name' with current changes?"
}

confirm_remove_worktree() {
  local name

  name="$1"
  gum confirm "Delete worktree '$name' and kill its tmux session?"
}

remove_worktree() {
  local name worktree_dir

  name="$1"
  log "remove_worktree name=$name"
  sanitize_name "$name"
  worktree_dir="$(worktree_path "$name")"

  [[ -d "$worktree_dir" ]] || die "Worktree does not exist: $worktree_dir"

  kill_tmux_session "$name"
  git worktree remove "$worktree_dir"
  log "remove_worktree removed name=$name dir=$worktree_dir"
}

has_local_changes() {
  [[ -n "$(git status --porcelain --untracked-files=all 2>/dev/null)" ]]
}

capture_worktree() {
  local name worktree_dir stash_message stash_ref

  name="$1"
  sanitize_name "$name"
  worktree_dir="$(worktree_path "$name")"
  log "capture_worktree name=$name dir=$worktree_dir"

  if ! has_local_changes; then
    log "capture_worktree no local changes; falling back to create"
    create_worktree "$name"
    return
  fi

  stash_message="git-worktree-session capture $name $(date '+%Y-%m-%d %H:%M:%S')"
  git stash push --include-untracked -m "$stash_message" >/dev/null
  stash_ref='stash@{0}'

  create_worktree_dir "$name"

  if git -C "$worktree_dir" stash apply --index "$stash_ref"; then
    git stash drop "$stash_ref" >/dev/null
  else
    die "Captured changes were stashed but could not be applied in $worktree_dir. Resolve manually with: git -C '$worktree_dir' stash apply --index $stash_ref"
  fi

  copy_local_files_to_worktree "$worktree_dir"

  ensure_tmux_session "$name"
  attach_or_switch "$name"
}

list_worktrees() {
  local wt_dir worktree_entry branch line name state

  wt_dir="$(worktrees_dir)"
  [[ -d "$wt_dir" ]] || return 0

  worktree_entry=''
  branch=''

  while IFS= read -r line; do
    if [[ "$line" == worktree\ * ]]; then
      worktree_entry="${line#worktree }"
    elif [[ "$line" == branch\ refs/heads/* ]]; then
      branch="${line#branch refs/heads/}"
    elif [[ -z "$line" ]]; then
      if [[ "$worktree_entry" == "$wt_dir"/* ]]; then
        name="${worktree_entry#$wt_dir/}"
        if [[ ! -d "$worktree_entry" ]]; then
          log "skipping missing worktree entry $worktree_entry"
          worktree_entry=''
          branch=''
          continue
        fi
        if has_tmux_session "$name"; then
          state='live'
        else
          state='stopped'
        fi
        print -- "$state	$name	${branch:-detached}	$worktree_entry"
      fi
      worktree_entry=''
      branch=''
    fi
  done < <(git worktree list --porcelain)

  if [[ -n "$worktree_entry" && "$worktree_entry" == "$wt_dir"/* ]]; then
    name="${worktree_entry#$wt_dir/}"
    if [[ ! -d "$worktree_entry" ]]; then
      log "skipping missing trailing worktree entry $worktree_entry"
      return 0
    fi
    if has_tmux_session "$name"; then
      state='live'
    else
      state='stopped'
    fi
    print -- "$state	$name	${branch:-detached}	$worktree_entry"
  fi
}

picker_rows() {
  local query line name

  query="${1:-}"

  if [[ -n "$query" ]]; then
    print -- "create\t$query\t+ create $query"
  fi

  while IFS= read -r line; do
    name="$(print -- "$line" | cut -f2)"
    if [[ -z "$query" || "${name:l}" == *"${query:l}"* ]]; then
      print -- "open\t$name\t$name"
    fi
  done < <(list_worktrees)
}

pick_worktree() {
  local selection action name header repo script_path key selected_line

  require_cmd fzf
  require_cmd gum
  log "pick_worktree begin"
  repo="$(repo_main_root)"
  header=$'enter: open/create  |  x: delete  |  up/down: move  |  ctrl-j/ctrl-k: move  |  esc: close\n'
  header+="repo: $repo"
  script_path="$(command -v git-worktree-session 2>/dev/null || print -- "${0:A}")"

  while true; do
    selection="$(
      picker_rows "" | fzf \
        --expect=enter,x \
        --delimiter=$'\t' \
        --with-nth=3 \
        --prompt='worktree> ' \
        --header="$header" \
        --disabled \
        --bind "start:reload:$script_path rows" \
        --bind "change:reload:$script_path rows {q}" \
        --bind 'ctrl-j:down' \
        --bind 'ctrl-k:up' \
        --no-preview
    )" || {
      log "pick_worktree fzf exited without selection"
      exit 0
    }

    key="$(print -- "$selection" | sed -n '1p')"
    selected_line="$(print -- "$selection" | sed -n '2p')"

    [[ -n "$selected_line" ]] || continue

    action="$(print -- "$selected_line" | cut -f1)"
    name="$(print -- "$selected_line" | cut -f2)"
    log "pick_worktree key=${key:-<empty>} action=${action:-<empty>} name=${name:-<empty>}"

    case "${key:-enter}:$action" in
      enter:create)
        if has_local_changes; then
          if confirm_capture_worktree "$name"; then
            capture_worktree "$name"
          else
            create_worktree "$name"
          fi
        else
          create_worktree "$name"
        fi
        return
        ;;
      enter:open)
        open_worktree "$name"
        return
        ;;
      x:open)
        if confirm_remove_worktree "$name"; then
          remove_worktree "$name"
        fi
        ;;
      x:create)
        ;;
      *)
        die "Unknown picker action: key=${key:-<empty>} action=${action:-<empty>}"
        ;;
    esac
  done
}

main() {
  require_cmd git
  require_cmd tmux
  log "start cwd=$PWD args=${*:-<none>}"
  repo_root >/dev/null || die 'Not inside a git repository'

  case "${1:-picker}" in
    picker)
      pick_worktree
      ;;
    create)
      [[ $# -eq 2 ]] || die 'Usage: git-worktree-session create <name>'
      create_worktree "$2"
      ;;
    open)
      [[ $# -eq 2 ]] || die 'Usage: git-worktree-session open <name>'
      open_worktree "$2"
      ;;
    rows)
      picker_rows "${2:-}"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "Unknown command: $1"
      ;;
  esac
}

main "$@"
